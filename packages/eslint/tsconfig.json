{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@ts-unify/core": ["../core/src/index.ts"],
      "@ts-unify/core/internal": ["../core/src/internal.ts"],
      "@ts-unify/engine": ["../engine/src/index.ts"],
      "@/*": ["../core/src/*"],
      "@": ["../core/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}

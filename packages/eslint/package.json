{
  "name": "@ts-unify/eslint",
  "version": "0.0.1",
  "description": "ESLint integration for ts-unify",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "default": "./dist/internal.js"
    }
  },
  "dependencies": {
    "@ts-unify/core": "0.0.1",
    "@ts-unify/engine": "0.0.1",
    "@typescript-eslint/utils": "^8.57.2",
    "eslint": "^10.1.0",
    "recast": "^0.23.11"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}

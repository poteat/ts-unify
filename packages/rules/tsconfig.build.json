{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": false,
    "baseUrl": ".",
    "paths": {
      "@ts-unify/core": ["../core/src/index.ts"],
      "@/*": ["../core/src/*"],
      "@": ["../core/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/test-utils"
  ]
}

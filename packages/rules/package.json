{
  "name": "@ts-unify/rules",
  "version": "0.0.1",
  "description": "Standard rule library for ts-unify",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json -r ./alias-replacer.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ts-unify/core": "0.0.1",
    "@typescript-eslint/types": "^8.43.0"
  },
  "peerDependencies": {
    "typescript": ">=5 <6"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}

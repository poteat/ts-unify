{
  "name": "@ts-unify/rules",
  "version": "0.0.1",
  "description": "Standard rule library for ts-unify",
  "main": "dist/index.mjs",
  "exports": {
    ".": {
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --external @ts-unify/core --external @typescript-eslint/types",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ts-unify/core": "0.0.1",
    "@typescript-eslint/types": "^8.43.0"
  },
  "peerDependencies": {
    "typescript": ">=5 <6"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}

{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": "./packages/core/src",
    "paths": {
      "@/*": ["*"],
      "@": ["index.ts"],
      "@ts-unify/core": ["index.ts"],
      "@ts-unify/core/internal": ["internal.ts"],
      "@ts-unify/engine": ["../../engine/src/index.ts"]
    }
  },
  "include": ["packages/core/src/**/*", "packages/engine/src/**/*", "packages/rules/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
